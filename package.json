{
  "name": "claude-to-figma",
  "version": "0.1.0",
  "private": true,
  "description": "Convert Claude Design HTML exports into editable Figma files",
  "license": "MIT",
  "author": "Brian Leach",
  "keywords": [
    "figma",
    "claude-design",
    "html",
    "css",
    "design-to-code",
    "figma-plugin",
    "auto-layout"
  ],
  "homepage": "https://github.com/brianleach/claude-to-figma#readme",
  "bugs": {
    "url": "https://github.com/brianleach/claude-to-figma/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brianleach/claude-to-figma.git"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "5.6.3",
    "vitest": "2.1.9",
    "tsup": "8.3.5"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  }
}

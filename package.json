{
  "name": "claude-to-figma",
  "version": "0.1.0",
  "private": true,
  "description": "Convert Claude Design HTML exports into editable Figma files",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianleach/claude-to-figma.git"
  },

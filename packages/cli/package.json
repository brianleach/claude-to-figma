{
  "name": "@claude-to-figma/cli",
  "version": "0.1.0",
  "private": true,
  "description": "CLI that parses Claude Design HTML exports into IR JSON",
  "license": "MIT",
  "type": "module",
  "bin": {
    "claude-to-figma": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "tsx scripts/integration.ts"
  },
  "dependencies": {
    "@claude-to-figma/ir": "workspace:*",
    "commander": "12.1.0",
    "parse5": "7.2.1",
    "postcss": "8.4.49",
    "yoga-layout": "3.2.1"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@vitest/coverage-v8": "2.1.8",
    "playwright": "1.49.0",
    "tsup": "8.3.5",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}

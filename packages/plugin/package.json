{
  "name": "@claude-to-figma/plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Figma plugin that builds a scene graph from claude-to-figma IR",
  "license": "MIT",
  "author": "Brian Leach",
  "keywords": ["figma", "figma-plugin", "claude-to-figma"],
  "homepage": "https://github.com/brianleach/claude-to-figma#readme",
  "bugs": {
    "url": "https://github.com/brianleach/claude-to-figma/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brianleach/claude-to-figma.git",
    "directory": "packages/plugin"
  },
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@claude-to-figma/ir": "workspace:*",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@figma/plugin-typings": "1.106.0",
    "@types/node": "22.9.0",
    "esbuild": "0.24.0",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
